{
  "name": "seesight",
  "private": true,
  "version": "0.1.0",
  "description": "SeeSight Business — AI-powered business travel management",
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run start:dev",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "lint:client": "npm --prefix client run lint",
    "lint:server": "npm --prefix server run lint",
    "test:server": "npm --prefix server test",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:postgres": "docker compose -f docker/docker-compose.yml up postgres -d"
  }
}
