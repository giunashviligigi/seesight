generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum TripStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalActionType {
  SUBMIT
  APPROVE
  REJECT
  COMMENT
}

enum NotificationType {
  TRIP_SUBMITTED
  TRIP_APPROVED
  TRIP_REJECTED
  EMPLOYEE_TEMP_PASSWORD
}

enum TravelClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

enum OfferProvider {
  AMADEUS
  SERPAPI
  MANUAL
  OTHER
}

enum BookingNeeds {
  BOTH
  FLIGHT_ONLY
  HOTEL_ONLY
}

// ─────────────────────────────────────────────
// Identity & organization
// ─────────────────────────────────────────────

model Company {
  id           String        @id @default(cuid())
  name         String
  legalName    String?
  slug         String        @unique
  country      String?
  billingEmail String?
  timezone     String        @default("UTC")
  status       CompanyStatus @default(ACTIVE)
  /// Soft policy stub for later milestones (budget defaults, etc.)
  policyJson   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  users           User[]
  departments     Department[]
  employees       Employee[]
  trips           Trip[]
  reportCaches    ReportCache[]

  @@index([status])
  @@index([deletedAt])
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  firstName          String?
  lastName           String?
  role               UserRole   @default(COMPANY_ADMIN)
  status             UserStatus @default(ACTIVE)
  /// True when account was provisioned with a temporary password (first login must set a new one).
  mustChangePassword Boolean    @default(false)
  companyId          String?
  company            Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  passwordResetTokens PasswordResetToken[]
  employeeProfile     Employee?
  tripsCreated        Trip[]               @relation("TripCreatedBy")
  approvalActions     ApprovalAction[]
  notifications       Notification[]

  @@index([companyId])
  @@index([status])
  @@index([role])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Department {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([deletedAt])
}

/// Company roster profile. May optionally link 1:1 to a User for login.
model Employee {
  id                String     @id @default(cuid())
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  userId            String?    @unique
  user              User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  email             String
  firstName         String
  lastName          String
  jobTitle          String?
  phone             String?
  nationality       String?
  passportNumber    String?
  preferredAirport  String?
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  tripTravelers TripTraveler[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────
// Trips & approvals
// ─────────────────────────────────────────────

model Trip {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId    String
  createdBy          User       @relation("TripCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  purpose            String
  destinationCountry String?
  destinationCity    String?
  startDate          DateTime   @db.Date
  endDate            DateTime   @db.Date
  budgetAmount       Decimal?   @db.Decimal(12, 2)
  budgetCurrency     String     @default("EUR")
  notes              String?
  bookingNeeds       BookingNeeds @default(BOTH)
  status             TripStatus @default(DRAFT)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  travelers           TripTraveler[]
  approval            Approval?
  flightOfferSnapshots FlightOfferSnapshot[]
  hotelOfferSnapshots  HotelOfferSnapshot[]
  aiRecommendations    AiRecommendation[]

  @@index([companyId])
  @@index([createdByUserId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt])
}

model TripTraveler {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([tripId, employeeId])
  @@index([tripId])
  @@index([employeeId])
}

model Approval {
  id           String         @id @default(cuid())
  tripId       String         @unique
  trip         Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  status       ApprovalStatus @default(PENDING)
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  actions ApprovalAction[]

  @@index([status])
}

model ApprovalAction {
  id         String             @id @default(cuid())
  approvalId String
  approval   Approval           @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  actorUserId String
  actor      User               @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  action     ApprovalActionType
  comment    String?
  createdAt  DateTime           @default(now())

  @@index([approvalId])
  @@index([actorUserId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  tripId    String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([tripId])
}

// ─────────────────────────────────────────────
// Travel search snapshots & AI / reports
// ─────────────────────────────────────────────

model FlightOfferSnapshot {
  id              String        @id @default(cuid())
  tripId          String
  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  provider        OfferProvider @default(SERPAPI)
  providerOfferId String?
  origin          String?
  destination     String?
  departAt        DateTime?
  returnAt        DateTime?
  travelClass     TravelClass?
  priceAmount     Decimal?      @db.Decimal(12, 2)
  currency        String?
  rawPayload      Json
  selected        Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([tripId])
  @@index([selected])
  @@index([provider])
}

model HotelOfferSnapshot {
  id              String        @id @default(cuid())
  tripId          String
  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  provider        OfferProvider @default(SERPAPI)
  providerOfferId String?
  hotelName       String?
  city            String?
  checkIn         DateTime?     @db.Date
  checkOut        DateTime?     @db.Date
  priceAmount     Decimal?      @db.Decimal(12, 2)
  currency        String?
  rawPayload      Json
  selected        Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([tripId])
  @@index([selected])
  @@index([provider])
}

model AiRecommendation {
  id             String   @id @default(cuid())
  tripId         String
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  provider       String
  promptSummary  String?
  responseJson   Json
  createdAt      DateTime @default(now())

  @@index([tripId])
  @@index([createdAt])
}

model ReportCache {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportKey   String
  payloadJson Json
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@unique([companyId, reportKey])
  @@index([companyId])
  @@index([expiresAt])
}
