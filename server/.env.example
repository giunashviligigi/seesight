# SeeSight API
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://seesight:seesight@localhost:5432/seesight?schema=public
CORS_ORIGIN=http://localhost:3000
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=dev-only-change-me-seesight-jwt
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=seesight_access_token

# Travel search (SerpAPI — Google Flights + Google Hotels)
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_CACHE_TTL_MS=60000
SERPAPI_RATE_LIMIT_PER_MINUTE=30
